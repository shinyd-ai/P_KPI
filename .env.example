DATABASE_URL="file:./prisma/dev.db"

# Turso production database
TURSO_DATABASE_URL="libsql://your-db-your-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-db-token"

# App-wide Basic Auth for private family use.
# Use ASCII values to avoid browser Basic Auth encoding differences.
BASIC_AUTH_USERNAME="your-username"
BASIC_AUTH_PASSWORD="your-strong-password"

# Optional: monthly review generation
ANTHROPIC_API_KEY="your-anthropic-api-key"
