DATABASE_URL="file:./prisma/dev.db"

# Turso production database
TURSO_DATABASE_URL="libsql://your-db-your-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-db-token"

# App login credentials. Use strong values in production.
APP_AUTH_USERNAME="your-username"
APP_AUTH_PASSWORD="your-strong-password"
AUTH_SECRET="your-random-32-byte-or-longer-secret"

# Optional: monthly review generation
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Optional: Discord daily KPI reminder
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."
CRON_SECRET="your-random-cron-secret"
APP_BASE_URL="https://your-app.example.com"
DISCORD_NOTIFICATION_TIME_ZONE="Asia/Seoul"
